# Claude Code Authentication
# Für Claude Max: Nutze dein bestehendes Login (claude login)
# Für API: Setze den API Key
# ANTHROPIC_API_KEY=sk-ant-...

# Pfad zum Projekt, an dem Claude arbeiten soll
PROJECT_DIR=/path/to/your/project

# Sekunden zwischen Task-Checks (default: 30)
RUNNER_INTERVAL=30

# Maximale Wiederholungen pro Task bei Fehler (default: 3)
MAX_RETRIES=3

# Log-Level: info oder debug (default: info)
LOG_LEVEL=info

# Worker-ID (nur relevant bei Multi-Worker Setup)
WORKER_ID=worker-1
