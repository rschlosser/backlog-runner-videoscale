# Claude Code Authentication
# For Claude Max: use your existing login (claude login)
# For API: set the API key
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub — used for task management via Issues
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# Telegram Bot (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USERS=123456789

# Slack Bot (optional — leave empty to disable)
# Create app at https://api.slack.com/apps with Socket Mode enabled
# Required scopes: chat:write, commands, files:read, im:history, channels:history
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_ALLOWED_USERS=U12345678,U87654321
SLACK_CHANNEL=C12345678

# Project branch to checkout (default: dev)
# PROJECT_BRANCH=dev

# Seconds between task checks (default: 30)
RUNNER_INTERVAL=30

# Max retry attempts per task (default: 3)
MAX_RETRIES=3

# Max verification retries per task (default: 3)
MAX_VERIFY_RETRIES=3

# Default verify command (optional, used when task has no verify: line)
# DEFAULT_VERIFY_CMD=pytest tests/ -x

# Deployment tokens (optional — needed for deploy commands)
# VERCEL_TOKEN=...
# RAILWAY_API_TOKEN=...

# Health monitoring interval in seconds (default: 300 = 5 min)
# MONITOR_INTERVAL=300
# Set to false to disable health monitoring
# MONITOR_ENABLED=true

# Log level: info or debug (default: info)
LOG_LEVEL=info

# Worker ID
WORKER_ID=worker-1
